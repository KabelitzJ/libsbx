#ifndef LIBSBX_VERSION_HPP_
#define LIBSBX_VERSION_HPP_

#define SBX_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SBX_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SBX_VERSION_PATCH @PROJECT_VERSION_PATCH@

#define SBX_VERSION ((SBX_VERSION_MAJOR << 16) | (SBX_VERSION_MINOR << 8) | SBX_VERSION_PATCH)
#define SBX_VERSION_STRING "@PROJECT_VERSION@"

#endif // LIBSBX_VERSION_HPP_