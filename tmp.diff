-
-  if (image_index >= sbx::common::max_image_array_size) {
-    result = normalize(normal);
-  } else {
-    float3 sampled_normal = images[NonUniformResourceIndex(image_index)].Sample(samplers[NonUniformResourceIndex(sampler_index)], uv).xyz;
