-  float3 T = normalize(input.tangent.xyz) * sign;
-
-  // Gram–Schmidt (important for stability)
-  T = normalize(T - N * dot(T, N));
-
-  float3 B = cross(N, T) * input.tangent.w;
-
-  return float3x3(T, B, N);
